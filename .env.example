# ──────────────────────────────────────────────────────────
# ECommerceApp — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=ecommerce_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# ── API ───────────────────────────────────────────────────
API_PORT=8080

# ── JWT ───────────────────────────────────────────────────
JWT_KEY=your_jwt_secret_key_at_least_32_characters_long
JWT_ISSUER=ECommerceApp
JWT_AUDIENCE=ECommerceApp
JWT_EXPIRY_MINUTES=60

# ── CORS (allowed frontend origins) ──────────────────────
ALLOWED_ORIGIN_0=http://localhost:4200
ALLOWED_ORIGIN_1=http://localhost:4300

# ── Cloudinary (image uploads) ────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (SMTP) ─────────────────────────────────────────
MAIL_ADDRESS=
MAIL_PASSWORD=
MAIL_DISPLAY_NAME=ECommerceApp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# ── Facebook OAuth (optional) ────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Google OAuth (optional) ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── pgAdmin (optional, for docker-compose) ───────────────
DB_PORT=5432
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@ecommerce.com
PGADMIN_PASSWORD=admin
