{
  "info": {
    "name": "ECommerceApp API",
    "description": "Complete API collection for ECommerceApp — ASP.NET Core 8 e-commerce backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5241/api/v1" },
    { "key": "token", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"9841234567\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\",\n  \"companyCode\": \"WOW001\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }",
                  "if (json.refresh_token) { pm.collectionVariables.set('refreshToken', json.refresh_token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"9841234567\",\n  \"password\": \"Password@123\",\n  \"companyCode\": \"WOW001\"\n}"
            }
          }
        },
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }",
                  "if (json.refresh_token) { pm.collectionVariables.set('refreshToken', json.refresh_token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/admin-login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"admin\",\n  \"password\": \"Admin@123\",\n  \"companyCode\": \"WOW001\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessToken\": \"{{token}}\",\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Send OTP (Forgot Password)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/sendopt?email=john@example.com", "host": ["{{baseUrl}}"], "path": ["auth", "sendopt"], "query": [{ "key": "email", "value": "john@example.com" }] }
          }
        },
        {
          "name": "Send Email OTP (Registration)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/sendemailotp?email=john@example.com", "host": ["{{baseUrl}}"], "path": ["auth", "sendemailotp"], "query": [{ "key": "email", "value": "john@example.com" }] }
          }
        },
        {
          "name": "Verify Email OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/verifyemail",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"otp\": \"123456\"\n}" }
          }
        },
        {
          "name": "Verify OTP + Reset Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/verifyopt",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewPassword@123\",\n  \"confirmPassword\": \"NewPassword@123\"\n}" }
          }
        },
        {
          "name": "Health Check",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/getecho" }
        },
        {
          "name": "Get Company Details",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/companydetails?companyCode=WOW001", "host": ["{{baseUrl}}"], "path": ["auth", "companydetails"], "query": [{ "key": "companyCode", "value": "WOW001" }] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/product?page=1&pageSize=20", "host": ["{{baseUrl}}"], "path": ["product"], "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }, { "key": "category", "value": "", "disabled": true }, { "key": "brand", "value": "", "disabled": true }, { "key": "color", "value": "", "disabled": true }, { "key": "search", "value": "", "disabled": true }, { "key": "topSelling", "value": "false", "disabled": true }] }
          }
        },
        {
          "name": "Get Product by Slug",
          "request": { "method": "GET", "url": "{{baseUrl}}/product/test-product" }
        },
        {
          "name": "Get Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/product/categories" }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/product",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Product\",\n  \"description\": \"Product description\",\n  \"price\": 99.99,\n  \"quantity\": 10,\n  \"categoryId\": 1,\n  \"companyInfoId\": 1\n}" }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/product/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Product\",\n  \"price\": 149.99\n}" }
          }
        },
        {
          "name": "Toggle Product Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/product/1/status",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": true\n}" }
          }
        },
        {
          "name": "Delete Product",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/product/1" }
        },
        {
          "name": "Seed Demo Data",
          "request": { "method": "POST", "url": "{{baseUrl}}/product/seed" }
        }
      ]
    },
